# Frontend runtime configuration
# Copy this file to .env.local and fill in the values you actually have.

VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_FAY_HTTP_BASE_URL=http://127.0.0.1:5000
VITE_FAY_WS_URL=ws://127.0.0.1:10002

# In production, the digital-human H5 page should use HTTPS + WSS.
# Example:
# VITE_FAY_WS_URL=wss://your-domain/ws/fay

# xmov / 魔珐星云 credentials
VITE_XMOV_APP_ID=your-xmov-app-id
VITE_XMOV_APP_SECRET=your-xmov-app-secret
