{
  "name": "kinecho-miniapp",
  "version": "1.0.0",
  "private": true,
  "description": "KinEcho 微信小程序端，包含老人、家属、服务人员三端。",
  "scripts": {
    "dev:weapp": "node scripts/dev-weapp.js",
    "build:weapp": "taro build --type weapp && node scripts/ensure-weapp-page-wxss.js && node scripts/patch-weapp-taro-node-getters.js && node scripts/check-weapp-bundle-budget.js",
    "smoke:checklist": "node scripts/smoke-checklist.js",
    "audit:security": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@tarojs/components": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "kinecho": "file:..",
    "qrcode-generator": "^2.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@tarojs/cli": "4.1.11",
    "@tarojs/plugin-framework-react": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/webpack5-runner": "4.1.11",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.23",
    "babel-preset-taro": "4.1.11",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "@tarojs/plugin-doctor": {
      "glob": "10.5.0"
    },
    "axios": "1.16.0",
    "download-git-repo": "file:./vendor/download-git-repo-disabled",
    "esbuild": "0.27.7",
    "got": "11.8.6",
    "html-minifier": "file:./vendor/html-minifier-safe",
    "http-cache-semantics": "4.2.0",
    "postcss-url": "file:./vendor/postcss-url-safe",
    "serialize-javascript": "7.0.5",
    "swiper": "12.1.4",
    "vm2": "3.11.2",
    "webpack": "5.105.0",
    "webpack-dev-server": "5.2.2"
  }
}
