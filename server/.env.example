FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Database
# 默认使用 MySQL。若仅做本地临时调试，可把 DB_DRIVER 改成 sqlite。
DB_DRIVER=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=kinecho
MYSQL_CHARSET=utf8mb4
MYSQL_AUTO_CREATE_DATABASE=true
SEED_DEMO_DATA=true

# SQLite fallback only
DATABASE_PATH=kinecho.db

HOST=0.0.0.0
PORT=8000

FAY_HTTP_BASE_URL=http://127.0.0.1:5000
FAY_MCP_BASE_URL=http://127.0.0.1:5010

AVATAR_CHAT_PROVIDER=deepseek
AVATAR_REQUIRE_YUESHEN_RAG=false
AVATAR_ENABLE_LOCAL_CHAT_FALLBACK=false

DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_CHAT_TEMPERATURE=0.9
DEEPSEEK_CHAT_MAX_TOKENS=500
DEEPSEEK_CHAT_TIMEOUT_SECONDS=45
