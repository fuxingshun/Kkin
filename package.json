{
  "name": "kinecho",
  "version": "2.0.0",
  "description": "KinEcho - 亲情回声：智能老人陪伴系统",
  "scripts": {
    "dev:admin": "vite --config config/vite.config.admin.ts --host 0.0.0.0",
    "build:admin": "tsc && vite build --config config/vite.config.admin.ts",
    "preview:admin": "vite preview --config config/vite.config.admin.ts --host 0.0.0.0 --port 3002",
    "server:build": "mvn -q -DskipTests package -f server-java/pom.xml",
    "server:start": "java -jar server-java/target/kinecho-server.jar",
    "server:dev": "mvn spring-boot:run -f server-java/pom.xml",
    "start:all": "scripts/start-all.cmd",
    "stop:all": "scripts/stop-all.cmd"
  },
  "keywords": [
    "elderly-care",
    "ai-companion",
    "family",
    "mini-program"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
